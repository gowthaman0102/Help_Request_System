<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.crowdhelp.frontend.ui.controller.LoginController"
           styleClass="login-root"
           minWidth="800" minHeight="620">

    <VBox alignment="CENTER" spacing="0">

        <!-- Header Brand -->
        <VBox alignment="CENTER" spacing="4" VBox.vgrow="ALWAYS">
            <Label text="ðŸ¤" styleClass="login-logo"/>
            <Label text="CrowdHelp" styleClass="login-title"/>
            <Label text="Your Community. Your Support." styleClass="login-subtitle"/>
        </VBox>

        <!-- Card -->
        <VBox styleClass="login-card" spacing="20" alignment="CENTER">

            <!-- Tab Toggle -->
            <HBox alignment="CENTER" spacing="0">
                <ToggleButton fx:id="loginTab" text="Sign In" selected="true" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <HBox.margin><Insets /></HBox.margin>
                    <toggleGroup>
                        <ToggleGroup fx:id="tabGroup"/>
                    </toggleGroup>
                </ToggleButton>
                <ToggleButton fx:id="registerTab" text="Register" maxWidth="Infinity" HBox.hgrow="ALWAYS" toggleGroup="$tabGroup"/>
            </HBox>

            <!-- Message Label -->
            <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="320" managed="false" visible="false"/>

            <!-- LOGIN PANE -->
            <VBox fx:id="loginPane" spacing="14">
                <VBox spacing="6">
                    <Label text="EMAIL" styleClass="form-label"/>
                    <TextField fx:id="loginEmail" promptText="your@email.com" styleClass="form-field" minWidth="320"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="PASSWORD" styleClass="form-label"/>
                    <PasswordField fx:id="loginPassword" promptText="â€¢â€¢â€¢â€¢â€¢â€¢â€¢â€¢" styleClass="form-field" minWidth="320"/>
                </VBox>
                <Button fx:id="loginBtn" text="Sign In â†’" styleClass="btn-primary"
                        maxWidth="Infinity" onAction="#handleLogin"/>
                <Label text="Demo: abc@example.com / password123" styleClass="meta-text" alignment="CENTER" maxWidth="Infinity" textAlignment="CENTER"/>
            </VBox>

            <!-- REGISTER PANE -->
            <VBox fx:id="registerPane" spacing="12" visible="false" managed="false">
                <HBox spacing="10">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="FULL NAME" styleClass="form-label"/>
                        <TextField fx:id="regName" promptText="John Doe" styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="LOCATION" styleClass="form-label"/>
                        <TextField fx:id="regLocation" promptText="Chennai" styleClass="form-field"/>
                    </VBox>
                </HBox>
                <VBox spacing="5">
                    <Label text="EMAIL" styleClass="form-label"/>
                    <TextField fx:id="regEmail" promptText="your@email.com" styleClass="form-field"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="PASSWORD" styleClass="form-label"/>
                    <PasswordField fx:id="regPassword" promptText="Min 6 characters" styleClass="form-field"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="SKILLS (comma-separated)" styleClass="form-label"/>
                    <TextField fx:id="regSkills" promptText="e.g. Blood Donation, Driving, Teaching" styleClass="form-field"/>
                </VBox>
                <Button fx:id="registerBtn" text="Create Account â†’" styleClass="btn-primary"
                        maxWidth="Infinity" onAction="#handleRegister"/>
            </VBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
    </VBox>
</StackPane>

